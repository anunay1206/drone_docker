    {
      "name": "2 \u00b7 Analyze via trigger (frontend path)",
      "item": [
        {
          "name": "runs/analyze (trigger)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}/runs/analyze",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "projects",
                "{{projectId}}",
                "runs",
                "analyze"
              ]
            },
            "description": "Starts analysis. mode=airflow if TCP_AIRFLOW_BASE_URL is set (backend calls the DAG), else local (in-process). Returns state/job_id/run_id \u2014 NO asset_id.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"run_name\": \"postman-run\",\n  \"model_key\": null,\n  \"source_epsg\": null,\n  \"params\": {\n    \"tile_size\": 10,\n    \"buffer\": 10,\n    \"iou_threshold\": 0.9,\n    \"conf_threshold\": 0.85,\n    \"pca_components\": 50,\n    \"batch_size\": 16,\n    \"img_size\": 224,\n    \"k_list\": [\n      2,\n      4,\n      6,\n      8,\n      10\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', ()=>pm.response.to.have.status(200));",
                  "var j=pm.response.json(); console.log('mode =', j.mode, '| run_id =', j.run_id);"
                ]
              }
            }
          ]
        },
