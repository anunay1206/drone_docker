    {
      "name": "3 \u00b7 Compute (what Airflow calls) \u2014 returns asset_id",
      "item": [
        {
          "name": "compute/analyze",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Service-Token",
                "value": "{{computeToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compute/analyze",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "compute",
                "analyze"
              ]
            },
            "description": "The DAG's analyze callback. Runs detection+clustering synchronously. 200 -> {asset_id, version, hosting_platform}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"execution_id\": \"{{$guid}}\",\n  \"project_id\": \"{{projectId}}\",\n  \"run\": \"{{run}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', ()=>pm.response.to.have.status(200));",
                  "var j=pm.response.json();",
                  "pm.test('has asset_id', ()=>pm.expect(j).to.have.property('asset_id'));",
                  "pm.test('has version', ()=>pm.expect(j).to.have.property('version'));",
                  "pm.test('has hosting_platform', ()=>pm.expect(j).to.have.property('hosting_platform'));",
                  "console.log('asset_id =', j.asset_id, '| version =', j.version, '| hosting_platform =', j.hosting_platform);"
                ]
              }
            }
          ]
        },
        {
          "name": "compute/finalize",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Service-Token",
                "value": "{{computeToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compute/finalize",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "compute",
                "finalize"
              ]
            },
            "description": "The DAG's finalize callback. Needs labels submitted (folder 4) + state LABELS_SUBMITTED. 200 -> {asset_id (KMZ), version, hosting_platform}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"execution_id\": \"{{$guid}}\",\n  \"project_id\": \"{{projectId}}\",\n  \"run\": \"{{run}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var j=pm.response.json(); console.log('status', pm.response.code, JSON.stringify(j));",
                  "if(pm.response.code===200){pm.test('has asset_id',()=>pm.expect(j).to.have.property('asset_id'));}"
                ]
              }
            }
          ]
        }
      ]
    },
