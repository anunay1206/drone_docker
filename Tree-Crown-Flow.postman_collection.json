    {
      "name": "5 \u00b7 Airflow REST (optional) \u2014 backend\u2192Airflow step",
      "item": [
        {
          "name": "trigger drone_analyze DAG",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{airflowUrl}}/api/v1/dags/{{analyzeDagId}}/dagRuns",
              "host": [
                "{{airflowUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dags",
                "{{analyzeDagId}}",
                "dagRuns"
              ]
            },
            "description": "What our backend does internally. Requires Airflow basic-auth (set on this request's Authorization tab to {{airflowUser}}/{{airflowPass}}). The DAG will then POST /compute/analyze back to the backend.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conf\": {\n    \"project_id\": \"{{projectId}}\",\n    \"run\": 1\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{airflowUser}}"
                },
                {
                  "key": "password",
                  "value": "{{airflowPass}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "trigger drone_finalize DAG",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{airflowUrl}}/api/v1/dags/{{finalizeDagId}}/dagRuns",
              "host": [
                "{{airflowUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dags",
                "{{finalizeDagId}}",
                "dagRuns"
              ]
            },
            "description": "Same, for finalize. Needs basic-auth.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conf\": {\n    \"project_id\": \"{{projectId}}\",\n    \"run\": 1\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{airflowUser}}"
                },
                {
                  "key": "password",
                  "value": "{{airflowPass}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
