# Copy to .env and adjust. All backend settings use the TCP_ prefix.

# ── storage & database (live on the mounted /data volume) ─────────────
TCP_STORAGE_ROOT=/data/storage
TCP_DATABASE_URL=sqlite:////data/treecrown.db

# ── model catalog ─────────────────────────────────────────────────────
# Detector weights live outside the repo. Set this host path to the folder that
# contains the .pth files named in code/models.yaml. It is mounted read-only at
# /models inside the API container.
HOST_MODELS_DIR=./models
TCP_MODELS_DIR=/models
TCP_MODELS_MANIFEST=/code/models.yaml
TCP_DEFAULT_MODEL_KEY=urban_cambridge

# ── run mode ──────────────────────────────────────────────────────────
# Compute runs in-process (.apply()); no Redis/Celery worker needed here.
TCP_CELERY_EAGER=false

# ── Airflow: full loop (configurable per host) ────────────────────────
# Our backend -> Airflow REST, to START a DAG run when the frontend hits
# /runs/analyze or /runs/finalize. Point this at wherever Airflow runs.
#   local Airflow on the same machine:  http://host.docker.internal:8080
#   remote Airflow:                     http://<airflow-host>:8080
TCP_AIRFLOW_BASE_URL=http://host.docker.internal:8080
TCP_ANALYZE_DAG_ID=drone_analyze
TCP_FINALIZE_DAG_ID=drone_finalize
# Airflow REST auth (basic-auth admin from `airflow standalone`, or a token):
TCP_AIRFLOW_USERNAME=admin
TCP_AIRFLOW_PASSWORD=
# TCP_AIRFLOW_AUTH_TOKEN=

# ── optional auth on our endpoints ────────────────────────────────────
# Protect the browser API:
# TCP_API_KEY=change-me
# Protect the compute callback the DAG calls (then set DRONE_SERVICE_TOKEN
# on the Airflow worker to the same value):
# TCP_COMPUTE_TOKEN=change-me

# ── uploads ───────────────────────────────────────────────────────────
TCP_MAX_UPLOAD_MB=8192

# ── build-time: torch wheel index (CPU default; cu118 for GPU) ─────────
# TORCH_INDEX=https://download.pytorch.org/whl/cu118
